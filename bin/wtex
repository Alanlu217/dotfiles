#!/usr/bin/env bash

file="$1"
filename="${file%%.*}"
extension="${file##*.}"
out="/tmp/wtyp.pdf"

if [[ -z "$file" ]]; then
  echo "Expecting filename"
  exit
fi

if [[ -z "$extension" || "$file" == "$extension" ]]; then
  file="${file}.typ"
fi

if [[ ! -f "$file" ]]; then
  tectonic -X compile -Z search-path=$HOME/dotfiles/twemojis $file
fi

evince "$out" &> /dev/null & disown

watchexec -c -i '*.pdf' -- tectonic -X compile -Z search-path=$HOME/dotfiles/twemojis $file >/dev/null 2>&1 & disown
WATCH_PID=$!
"$EDITOR" "$file"
kill "$WATCH_PID"

