#!/usr/bin/env python3

import os
import subprocess
import argparse

desktops = {
    "Hyprland": {
        "daemon": "hypridle",
        "command": ["hypridle"],
    },
    "niri": {
        "daemon": "swayidle",
        "command": [
            "swayidle",
            "timeout",
            "100",
            "brightnessctl -s set 5",
            "resume",
            "brightnessctl -r",
            "timeout",
            "110",
            "niri msg action power-off-monitors",
            "resume",
            "niri msg action power-on-monitors",
            "timeout",
            "120",
            "hyprlock",
            "before-sleep",
            "hyprlock",
        ],
    },
    "sway": {
        "daemon": "swayidle",
        "command": [
            "swayidle",
            "timeout",
            "100",
            "brightnessctl -s set 5",
            "resume",
            "brightnessctl -r",
            "timeout",
            "110",
            "swaymsg 'output * power off'",
            "resume",
            "swaymsg 'output * power on'",
            "timeout",
            "120",
            "hyprlock",
            "before-sleep",
            "hyprlock",
        ],
    },
}

desktop = os.environ.get("XDG_CURRENT_DESKTOP")
if desktop not in desktops:
    print("Desktop not supported")
    os._exit(0)

daemon = desktops[desktop]["daemon"]
command = desktops[desktop]["command"]


def run(cmd):
    subprocess.Popen(
        cmd,
        start_new_session=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def notify_waybar():
    run(["pkill", "-RTMIN+1", "waybar"])
    run(["pkill", "-RTMIN+1", ".waybar-wrapped"])


def is_running():
    return subprocess.run(["pidof", daemon], capture_output=True).returncode == 0


def instant_idle():
    swayidle = subprocess.Popen(
        [
            "swayidle",
            "timeout",
            "1",
            "hyprctl dispatch dpms off",
            "resume",
            "hyprctl dispatch dpms on",
        ]
    )
    subprocess.run(["hyprlock"])
    swayidle.terminate()


parser = argparse.ArgumentParser()
sub = parser.add_subparsers(dest="cmd", required=True)
sub.add_parser("start", help="Start the idle daemon")
sub.add_parser("stop", help="Kill the idle daemon")
sub.add_parser("toggle", help="Start if stopped, stop if running")
sub.add_parser("now", help="Trigger idle now")
sub.add_parser("running", help="Check if the idle daemon is running")

args = parser.parse_args()

if args.cmd == "start":
    run(command)
elif args.cmd == "stop":
    run(["killall", daemon])
elif args.cmd == "toggle":
    if is_running():
        run(["killall", daemon])
    else:
        run(command)
elif args.cmd == "now":
    instant_idle()
elif args.cmd == "running":
    print("on" if is_running() else "off")

notify_waybar()
